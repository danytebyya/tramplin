APP_NAME=Tramplin API
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:5173

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tramplin
POSTGRES_USER=tramplin_user
POSTGRES_PASSWORD=tramplin_password

DATABASE_URL=postgresql+psycopg://tramplin_user:tramplin_password@localhost:5432/tramplin

JWT_SECRET_KEY=replace_with_a_random_secret_key_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ISSUER=tramplin-api

OTP_CODE_LENGTH=6
OTP_CODE_TTL_SECONDS=900
OTP_REQUEST_LIMIT=3
OTP_REQUEST_WINDOW_SECONDS=900
OTP_VERIFY_ATTEMPT_LIMIT=5
AUTH_EMAIL_CHECK_LIMIT=20
AUTH_EMAIL_CHECK_WINDOW_SECONDS=300
AUTH_LOGIN_ATTEMPT_LIMIT=5
AUTH_LOGIN_ATTEMPT_WINDOW_SECONDS=900
AUTH_LOGIN_BLOCK_SECONDS=900
AUTH_LOGIN_IP_ATTEMPT_LIMIT=20
AUTH_LOGIN_IP_ATTEMPT_WINDOW_SECONDS=900
AUTH_LOGIN_IP_BLOCK_SECONDS=900
EMAIL_SENDER_NAME=Tramplin
EMAIL_TRANSPORT=log
EMAIL_SENDER_ADDRESS=no-reply@tramplin.local
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=10

DADATA_API_KEY=
DADATA_SUGGESTIONS_URL=https://suggestions.dadata.ru/suggestions/api/4_1/rs/suggest/party
DADATA_TIMEOUT_SECONDS=5

INITIAL_ADMIN_EMAIL=admin@tramplin.local
INITIAL_ADMIN_PASSWORD=ChangeMe123
INITIAL_ADMIN_DISPLAY_NAME=Platform Admin
